@prefix example: <https://dynamicontology.com/otdd/examples/complexType-element#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

example:AddressType
    a owl:Class .

example:Address
    a owl:ObjectProperty ;
    rdfs:range example:AddressType .

# ---------------------------------------------------------------------------
# OTDD Example
# ---------------------------------------------------------------------------
# Case ID:
#     o-missing-opinion-of-value-type-1
#
# Expected Result:
#     INVALID
#
# RDF Component:
#     Object
#
# Defect Category:
#     Missing Object Type
#
# Target Concept:
#     OpinionOfValue
#
# Shape Under Test:
#     uad:AppraisalShape
#
# Constraint Under Test:
#     sh:class uad:OpinionOfValue
#
# Expected SHACL Result:
#     Violation
#
# Purpose:
#     Demonstrates that an appraisal references an OpinionOfValue resource
#     whose rdf:type declaration is missing.
#
# Related Examples:
#     o-absent-opinion-of-value-1.ttl
#     p-missing-opinion-of-value-1.ttl
#     full-valid-appraisal.ttl
#
# Notes:
#     The appraisal references ex:opinion-001, but that resource has no
#     rdf:type uad:OpinionOfValue declaration. A different resource,
#     ex:opinion-x, is correctly typed, but it is not the object referenced
#     by the appraisal.
# ---------------------------------------------------------------------------
@prefix ex:   <https://dynamicontology.com/uad36/example#> .
@prefix uad:  <https://dynamicontology.com/uad36/ontology#> .

ex:appraisal-001
    a uad:Appraisal ;
    uad:appraisesProperty ex:subject-property-001 ;
    uad:hasOpinionOfValue ex:opinion-001 ;
    uad:usesValuationApproach ex:sales-comparison-approach-001 ;
    uad:hasReconciliation ex:reconciliation-001 .

ex:subject-property-001
    a uad:SubjectProperty .

ex:opinion-x
    a uad:OpinionOfValue .

ex:sales-comparison-approach-001
    a uad:SalesComparisonApproach .

ex:reconciliation-001
    a uad:Reconciliation .
